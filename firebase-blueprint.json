{
  "entities": {
    "WaitlistEntry": {
      "title": "Waitlist Entry",
      "description": "A single entry in the waitlist tracking interested users.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user joined the waitlist."
        }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/waitlist/{entryId}": {
      "schema": "WaitlistEntry",
      "description": "Collection of waitlist entries."
    }
  }
}
