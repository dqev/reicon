{
  "name": "reicon-docs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "node scripts/generate-sitemap.mjs && vite build && node scripts/prerender-meta.mjs",
    "build:og": "node scripts/generate-og-images.mjs",
    "build:full": "npm run build && npm run build:og",
    "postbuild": "node scripts/ping-search-engines.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "ping": "node scripts/ping-search-engines.mjs",
    "seo:check": "node scripts/test-seo.mjs",
    "build:react": "node packages/reicon-react/scripts/build.cjs",
    "build:vue": "node packages/reicon-vue/scripts/build.cjs",
    "build:js": "node packages/reicon/scripts/build.cjs",
    "build:cdn:min": "npx terser packages/reicon/dist/cdn/reicon.js --compress --mangle -o packages/reicon/dist/cdn/reicon.min.js",
    "build:figma": "node packages/reicon-figma/scripts/build.cjs",
    "build:svelte": "node packages/reicon-svelte/scripts/build.cjs",
    "build:vscode": "node packages/reicon-vscode/scripts/build.cjs",
    "build:packages": "npm run build:react && npm run build:vue && npm run build:js && npm run build:cdn:min && npm run build:figma && npm run build:svelte && npm run build:vscode",
    "preview": "vite preview",
    "clean": "rm -rf dist packages/*/dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "jszip": "^3.10.1",
    "lenis": "^1.3.23",
    "motion": "^12.40.0",
    "posthog-node": "^5.34.6",
    "react": "^19.0.1",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.0.1",
    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.6.0",
    "reicon-react": "^1.0.4",
    "sharp": "^0.34.5",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vue": "^3.5.39"
  }
}
