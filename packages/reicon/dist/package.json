{
  "name": "reicon",
  "version": "1.0.0",
  "type": "module",
  "description": "2680+ pixel-perfect SVG icons for React, Vue, and vanilla JS. Tree-shakeable, zero dependencies, TypeScript-ready. Outline & Filled weights.",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "unpkg": "./umd/reicon.js",
  "jsdelivr": "./umd/reicon.js",
  "browser": "./umd/reicon.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    },
    "./icons/*": {
      "import": "./icons/*.js",
      "types": "./icons/*.d.ts"
    },
    "./createIcon": {
      "import": "./createIcon.js",
      "types": "./createIcon.d.ts"
    },
    "./element": {
      "import": "./cdn/reicon.js"
    },
    "./cdn/*": {
      "import": "./cdn/*.js"
    }
  },
  "sideEffects": false,
  "files": [
    "index.js",
    "index.d.ts",
    "createIcon.js",
    "createIcon.d.ts",
    "icons/",
    "umd/",
    "cdn/",
    "README.md"
  ],
  "keywords": [
    "icons",
    "svg",
    "svg-icons",
    "icon-library",
    "icon",
    "ui-icons",
    "react-icons",
    "vue-icons",
    "svelte-icons",
    "outline-icons",
    "filled-icons",
    "reicon",
    "tree-shakeable",
    "tree-shaking",
    "typescript",
    "zero-dependencies",
    "javascript",
    "vanilla-js",
    "cdn",
    "pixel-perfect",
    "open-source",
    "figma-icons",
    "handcrafted-icons",
    "web-icons"
  ],
  "author": {
    "name": "devchauhan",
    "email": "dev@devchauhan.in",
    "url": "https://devchauhan.in"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dqev/reicon.git"
  },
  "bugs": {
    "url": "https://github.com/dqev/reicon/issues"
  },
  "homepage": "https://reicon.dev"
}