{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "node",
    "declaration": true,
    "sourceMap": true,
    "inlineSources": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "lib": ["dom", "es2022"],
    "skipLibCheck": true,
    "baseUrl": "./"
  },
  "angularCompilerOptions": {
    "enableResourceInlining": true,
    "strictTemplateAccessModifiers": true,
    "strictMetadataEmit": true,
    "flatModuleId": "reicon-angular"
  }
}
